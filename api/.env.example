# Coviction API Configuration

# Copy this to .env and fill in your values



# Database (PostgreSQL — async connection string)

DATABASE_URL=postgresql+asyncpg://coviction:dev_password@localhost:5432/coviction



# OpenAI API

OPENAI_API_KEY=sk-proj-your-key-here

# OPENAI_BASE_URL=          # Uncomment only if using a proxy



# Models

DEFAULT_STRONG_MODEL=gpt-4o-mini

DEFAULT_FAST_MODEL=gpt-4o-mini



# Security (CHANGE IN PRODUCTION)

# JWT_SECRET=your-random-64-char-hex-string

# DEBUG=False

# CORS_ORIGINS=https://your-domain.com
